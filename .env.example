# .env Template - Payment Methods Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════════
# 💳 PAYMENT METHODS CONFIGURATION (External links handled off-bot)
# ═══════════════════════════════════════════════════════════════════════════════

# ⭐ TELEGRAM STARS (Built-in) - works out of the box, no config needed

# 💳 PAYPAL PAYMENT METHOD
# Put your PayPal.me link or payment page URL
PAYPAL_ID=paypal.me/yourname

# 🏦 UPI PAYMENT METHOD (India)
# Put a link/page that shows your UPI QR/ID for users to pay
UPI_ID=yourname@bankname

# ₿ CRYPTOCURRENCY PAYMENT METHOD
# Put your wallet address (USDT/BTC/etc.)
CRYPTO_WALLET=your_wallet_address
CRYPTO_TYPE=usdt
BINANCE_PAY_ID=your_binance_pay_id

# ═══════════════════════════════════════════════════════════════════════════════
# 📝 CONTACT INFORMATION FOR PAYMENTS
# ═══════════════════════════════════════════════════════════════════════════════

# Your Telegram username (without @) for payment support inquiries
OWNER_USERNAME=YourUsername

# Support team Telegram username
SUPPORT_USERNAME=YourSupportUsername

# ═══════════════════════════════════════════════════════════════════════════════
# CONFIGURATION EXAMPLES
# ═══════════════════════════════════════════════════════════════════════════════

# Example: simple setup
# PAYPAL_ID=paypal.me/yourname
# UPI_ID=yourname@okhdfcbank
# CRYPTO_WALLET=0x1234abcd...
# CRYPTO_TYPE=usdt
# BINANCE_PAY_ID=your_binance_pay_id

# ═══════════════════════════════════════════════════════════════════════════════
# PAYPAL SETUP DETAILS
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Go to https://www.paypal.com/business
# 2. Create Business Account
# 3. Verify your account
# 4. Copy your business email and paste as PAYPAL_ID
#
# Test with: https://paypal.me/{email}
# Replace {email} with the part before @ in your PayPal email

# ═══════════════════════════════════════════════════════════════════════════════
# UPI SETUP DETAILS
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Open your bank's mobile app
# 2. Find "UPI" or "Pay" section
# 3. Create or view your UPI ID (format: username@bankname)
# 4. Copy and paste as UPI_ID
#
# Common bank UPI formats:
# - HDFC Bank: yourname@okhdfcbank
# - ICICI Bank: yourname@ikici
# - Axis Bank: yourname@axisbank
# - SBI: yourname@oksbi
# - PhonePe/Google Pay: yourname@ybl

# ═══════════════════════════════════════════════════════════════════════════════
# CRYPTOCURRENCY SETUP DETAILS
# ═══════════════════════════════════════════════════════════════════════════════
# Bitcoin Wallet Setup:
# 1. Create account on Coinbase, Kraken, or use MetaMask
# 2. Generate a Bitcoin wallet address
# 3. Copy the address (starts with 1, 3, or bc1)
# 4. Paste as CRYPTO_WALLET
#
# Ethereum Setup:
# 1. Create MetaMask wallet or use exchange
# 2. Generate Ethereum wallet address
# 3. Copy address (starts with 0x)
# 4. Paste as CRYPTO_WALLET
# 5. Set CRYPTO_TYPE=ethereum
#
# Example Bitcoin Wallet: 1A1z7agoat5w2BgUtiMB6triCqWTiAQWP
# Example Ethereum Wallet: 0x742d35Cc6634C0532925a3b844Bc28e65f308995

# ═══════════════════════════════════════════════════════════════════════════════
# STRIPE (CREDIT/DEBIT CARDS) SETUP DETAILS
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Go to https://stripe.com
# 2. Create account and complete verification
# 3. Go to Developers → API Keys
# 4. Copy your "Secret Key" (starts with sk_live_ or sk_test_)
# 5. Paste as STRIPE_API_KEY
#
# Create Payment Link:
# 1. Dashboard → Payment Links
# 2. Create new link with your prices
# 3. Copy link and update premium.py send_card_payment_link()
#
# For Webhook Setup (auto-activation):
# 1. Go to Developers → Webhooks
# 2. Create endpoint for payment success
# 3. Handle webhook in your backend

# ═══════════════════════════════════════════════════════════════════════════════
# PRICES REFERENCE
# ═══════════════════════════════════════════════════════════════════════════════
# Telegram Stars prices are set in info.py PREMIUM_PRICES:
#     1: 11,      # 1 Day - 11 Stars
#     7: 60,      # 7 Days - 60 Stars
#     15: 110,    # 15 Days - 110 Stars
#     30: 185,    # 30 Days - 185 Stars
#     60: 340,    # 60 Days - 340 Stars
#     90: 480,    # 90 Days - 480 Stars
#
# Non-Star prices (PayPal, UPI, Crypto, Cards) in info.py PAYMENT_PRICES_USD:
#     1: 1.99,
#     7: 10.99,
#     15: 19.99,
#     30: 35.99,
#     60: 65.99,
#     90: 95.99,
#
# Customize these in info.py if needed

# ═══════════════════════════════════════════════════════════════════════════════
# ADMIN COMMANDS FOR MANUAL PAYMENT VERIFICATION
# ═══════════════════════════════════════════════════════════════════════════════
# When user sends payment via PayPal/UPI/Crypto:
#
# 1. User sends payment proof to your support account
# 2. You verify the payment in PayPal/UPI/Crypto
# 3. Activate premium with:
#    /addpremium <user_id> <days>
#    /addpremium 123456789 30
#
# 4. User automatically receives confirmation
#
# To remove premium:
#    /removepremium <user_id>
#
# To see all premium users:
#    /premiumusers

# ═══════════════════════════════════════════════════════════════════════════════
# IMPORTANT SECURITY NOTES
# ═══════════════════════════════════════════════════════════════════════════════
# ⚠️  NEVER commit .env file to git/version control
# ⚠️  NEVER share your API keys or wallet addresses in code
# ⚠️  Keep your crypto wallet addresses secure
# ⚠️  Use environment variables on deployment platforms
# ⚠️  Rotate Stripe keys regularly
# ⚠️  Verify all manual payments before activating premium

# ═══════════════════════════════════════════════════════════════════════════════
# TESTING
# ═══════════════════════════════════════════════════════════════════════════════
# Test each payment method:
#
# 1. Enable only Telegram Stars, test it works
# 2. Enable PayPal, verify button shows and link works
# 3. Enable UPI, verify button shows and UPI link opens
# 4. Enable Crypto, verify wallet displays correctly
# 5. Enable Cards, verify Stripe link works
#
# Use test mode IDs when available:
# - Stripe: Use sk_test_ keys with test cards (4242 4242 4242 4242)
# - PayPal: Use sandbox.paypal.com credentials

# ═══════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT PLATFORMS
# ═══════════════════════════════════════════════════════════════════════════════
# Heroku: Set env vars in Config Vars
# Railway: Add to Variables
# Render: Add to Environment
# Cloud Run: Set as Secret Manager values
# Docker: Pass with -e flag or in docker-compose.yml

